[Unit]
Description=Arthas Trading Dashboard API — FastAPI/uvicorn
After=network.target postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/trading
EnvironmentFile=/opt/trading/config/.env
ExecStart=/opt/trading/venv/bin/uvicorn api.main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
